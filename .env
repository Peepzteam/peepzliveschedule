# ── Google OAuth2 ─────────────────────────────────────
# 1. ไปที่ https://console.cloud.google.com
# 2. สร้าง Project ใหม่ (หรือใช้อันเดิม)
# 3. เปิด APIs: Gmail API + Google Calendar API
# 4. OAuth consent screen → External → ใส่ email ของแพร
# 5. Credentials → Create OAuth 2.0 Client ID → Web application
# 6. Authorized redirect URIs → เพิ่ม: http://localhost:3000/auth/callback
# 7. Copy Client ID และ Client Secret มาใส่ด้านล่าง
GOOGLE_CLIENT_ID=919991449189-jr1tl3pve5eg3alnbe8kqh72egh1fct4.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Session ──────────────────────────────────────────
# เปลี่ยนเป็น string random ของตัวเองได้
SESSION_SECRET=peepz_secretary_2026

# ── Server ───────────────────────────────────────────
