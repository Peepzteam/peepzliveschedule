# ════════════════════════════════════════════════════
#  เลขา — Peepz Team  |  Environment Variables
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงก่อนรันค่า
# ════════════════════════════════════════════════════

# ── ClickUp ──────────────────────────────────────────
# หาได้ที่ ClickUp → Profile → Apps → API Token
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic Claude ─────────────────────────────────
# หาได้ที่ https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model ที่ใช้ (เปลี่ยนได้ถ้าต้องการ)
CLAUDE_MODEL=claude-sonnet-4-5

# ── Google OAuth2 ─────────────────────────────────────
# 1. ไปที่ https://console.cloud.google.com
# 2. สร้าง Project ใหม่ (หรือใช้อันเดิม)
# 3. เปิด APIs: Gmail API + Google Calendar API
# 4. OAuth consent screen → External → ใส่ email ของแพร
# 5. Credentials → Create OAuth 2.0 Client ID → Web application
# 6. Authorized redirect URIs → เพิ่ม: http://localhost:3000/auth/callback
# 7. Copy Client ID และ Client Secret มาใส่ด้านล่าง
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Session ──────────────────────────────────────────
# เปลี่ยนเป็น string random ของตัวเองได้
SESSION_SECRET=peepz_secretary_2026

# ── Server ───────────────────────────────────────────
PORT=3000
